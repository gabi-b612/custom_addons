<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//article" position="attributes">

            <attribute name="t-att-class">this.isDisabled ? 'product-disabled' : ''</attribute>

        </xpath>
        <xpath expr="//div[hasclass('product-information-tag')]" position="before">
            <t t-if="value.display_stock">
                <div class="product-stock-info">
                    <t t-if="pos.res_setting['stock_from'] == 'all_warehouse'">
                        <t t-if="pos.res_setting['stock_type'] == 'incoming_qty'">
                            <span class="stock-quantity-badge"
                                  t-att-class="state.incoming_qty > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="state.incoming_qty"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'outgoing_qty'">
                            <span class="stock-quantity-badge"
                                  t-att-class="state.outgoing_qty > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="state.outgoing_qty"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'forecasted'">
                            <span class="stock-quantity-badge"
                                  t-att-class="state.virtual_available > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="state.virtual_available"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'on_hand'">
                            <span class="stock-quantity-badge"
                                  t-att-class="state.qty_available > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="state.qty_available"/>
                            </span>
                        </t>
                    </t>
                    <t t-if="pos.res_setting['stock_from'] == 'current_warehouse'">
                        <t t-if="pos.res_setting['stock_type'] == 'incoming_qty'">
                            <span class="stock-quantity-badge"
                                  t-att-class="props.incoming_loc > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="props.incoming_loc"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'outgoing_qty'">
                            <span class="stock-quantity-badge"
                                  t-att-class="props.outgoing > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-esc="props.outgoing"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'on_hand'">
                            <span class="stock-quantity-badge"
                                  t-att-class="props.on_hand > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-out="props.on_hand"/>
                            </span>
                        </t>
                        <t t-if="pos.res_setting['stock_type'] == 'forecasted'">
                            <span class="stock-quantity-badge"
                                  t-att-class="props.product.virtual_available > 0 ? 'stock-available' : 'stock-unavailable'">
                                <span class="stock-quantity-label">Qty:</span>
                                <span class="stock-quantity-value" t-out="props.product.virtual_available"/>
                            </span>
                        </t>
                    </t>
                    <t t-if="pos.config.show_product_trend">
                        <span class="stock-trend-container" t-att-class="{
                            'trend-up': props.product.stock_trend === 'increasing',
                            'trend-down': props.product.stock_trend === 'decreasing',
                            'trend-neutral': props.product.stock_trend === 'neutral'
                        }">
                            <span class="stock-trend-icon"
                                  t-att-title="'Sold: ' + (props.product.total_sold || 0) + ' | Purchased: ' + (props.product.total_added || 0)"
                                  />
                        </span>
                    </t>
                </div>
            </t>
        </xpath>
    </t>
</templates>