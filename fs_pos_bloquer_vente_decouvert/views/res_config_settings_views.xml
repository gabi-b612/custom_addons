<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fs_res_config_settings_view_form_pos_block_negative" model="ir.ui.view">
        <field name="name">fs.res.config.settings.pos.block.negative.sale</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='point_of_sale']" position="inside">
                <block title="Point de vente — Stock" id="fs_pos_stock_block_section">

                    <setting string="Bloquer la vente à découvert"
                             help="Empêche la vente des produits dont le stock est à 0 ou négatif dans le POS.">
                        <field name="fs_block_negative_sale"/>
                    </setting>

                    <setting string="Message de blocage"
                             help="Message affiché dans le POS lorsqu’un produit ne peut pas être ajouté (stock insuffisant).">
                        <field name="fs_block_negative_message"
                               placeholder="Ex: Stock insuffisant : vente à découvert interdite."
                               invisible="not fs_block_negative_sale"/>
                    </setting>

                    <setting string="Emplacement de stock (optionnel)"
                             help="Si vide, Odoo utilisera l’emplacement source du POS (picking type).">
                        <field name="fs_stock_location_id"
                               domain="[('usage', '=', 'internal')]"
                               invisible="not fs_block_negative_sale"/>
                    </setting>

                </block>
            </xpath>

        </field>
    </record>

</odoo>
