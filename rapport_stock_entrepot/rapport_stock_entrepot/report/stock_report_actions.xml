<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_stock_report_pdf" model="ir.actions.report">
        <field name="name">Rapport Stock Entrepôt</field>

        <!-- IMPORTANT : doit correspondre exactement au modèle -->
        <field name="model">stock.warehouse.report</field>

        <field name="report_type">qweb-pdf</field>

        <!-- Doit correspondre au template -->
        <field name="report_name">rapport_stock_entrepot.stock_report_pdf</field>
        <field name="report_file">rapport_stock_entrepot.stock_report_pdf</field>

        <!-- Nom du fichier PDF téléchargé -->
        <field name="print_report_name">
            (object.name or 'Rapport_Stock') + '_' + (object.date_report and object.date_report.strftime('%Y-%m-%d') or '')
        </field>
    </record>

</odoo>