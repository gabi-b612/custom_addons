<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_stock_wh_report" model="mail.template">
        <field name="name">Rapport Stock Entrepôt (PDF)</field>
        <field name="model_id" ref="model_stock_warehouse_report"/>
        <field name="subject">Rapport de stock — ${object.warehouse_id.display_name}</field>
        <field name="body_html">
            <![CDATA[
            <p>Bonjour,</p>
            <p>Veuillez trouver ci-joint le rapport de stock de l'entrepôt
               <strong>${object.warehouse_id.display_name}</strong>.</p>
            <p>Cordialement.</p>
            ]]>
        </field>
    </record>

</odoo>
